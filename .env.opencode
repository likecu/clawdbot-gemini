# OpenCode 服务配置文件
# 注意：此文件包含敏感信息，请勿提交到版本控制

# OpenRouter API 配置（主要使用）
OPENROUTER_API_KEY=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
OPENROUTER_API_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=deepseek/deepseek-r1

# MCP 服务器配置
# 格式: 服务器名称 命令 参数
# 官方 MCP 服务器包名: @modelcontextprotocol/server-*
MCP_SERVERS=fetch npx -y @modelcontextprotocol/server-fetch, filesystem npx -y @modelcontextprotocol/server-filesystem /tmp

# OpenCode 服务自身配置
OPENCODE_API_KEY=my_internal_secret_2024
OPENCODE_HOST=0.0.0.0
OPENCODE_PORT=8080
OPENCODE_DEBUG=false

# 日志配置
LOG_LEVEL=INFO
